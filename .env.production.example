# Production environment variables for QueueFlow.
# On Render these are set via the blueprint / dashboard; this file documents them.

# --- Required secrets ---
# Neon Postgres (durable audit log). Keep sslmode=require.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
# Upstash Redis (queue engine). The rediss:// scheme enables TLS automatically.
REDIS_URL=rediss://default:PASSWORD@HOST:PORT
# Strong random string — the API refuses to boot in production with the dev default.
JWT_SECRET=replace-with-a-long-random-secret

# --- Runtime ---
NODE_ENV=production
# Render injects PORT; the API listens on it automatically.
# Comma-separated browser origins (or bare hosts) allowed by CORS.
CORS_ORIGINS=https://your-dashboard.onrender.com

# Run the worker loop inside the API process (single free service). Set to false
# and deploy a dedicated worker service to scale processing horizontally.
RUN_WORKER_INLINE=true

# --- Worker tuning (raise to cut Redis request volume on Upstash) ---
WORKER_CONCURRENCY=4
WORKER_POLL_MS=250
WORKER_MAX_IDLE_MS=5000
WORKER_MAINTENANCE_MS=5000
WORKER_DEPTH_MS=10000
LEASE_MS=30000

# --- Frontend (build-time, baked into the static export) ---
# NEXT_PUBLIC_API_URL=https://your-api.onrender.com
