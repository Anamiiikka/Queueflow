# Copy to .env and adjust as needed. The npm scripts auto-load .env if present
# (via Node's --env-file-if-exists), so a local .env overrides these defaults.
REDIS_URL=redis://localhost:6379

# Local Docker Postgres by default. For a managed DB (e.g. Neon), set DATABASE_URL
# to its connection string with sslmode=require — no code changes needed.
DATABASE_URL=postgres://queueflow:queueflow@127.0.0.1:5440/queueflow
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

LOG_LEVEL=info
WORKER_CONCURRENCY=4
LEASE_MS=30000
